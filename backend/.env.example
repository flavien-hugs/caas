APP_NAME=caas
APP_VERSION="0.1.0"
HIDE_DOCS=false
ENVIRONMENT=dev   # "staging", "production"
LOG_LEVEL=INFO

# Postgres container credentials (used by compose.override.yaml).
# Keep these in sync with DATABASE_URL.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=caas

DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

REDIS_URL=redis://redis:6379/1
REDIS_NAMESPACE=v2

CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3
CELERY_DEFAULT_QUEUE=v2_default

PAYMENT_PROVIDER=kkiapay  # "cinetpay"

KKIAPAY_PUBLIC_KEY=
KKIAPAY_PRIVATE_KEY=
KKIAPAY_SECRET_KEY=
KKIAPAY_URL=https://api.kkiapay.me
KKIAPAY_SANDBOX_URL=https://api-sandbox.kkiapay.me
KKIAPAY_TRANSACTION_STATUS_URL=/api/v1/transactions/status
KKIAPAY_SANDBOX=true

# CinetPay (env defaults; the DB "cinetpay" config section overrides them).
CINETPAY_SITE_ID=
CINETPAY_API_KEY=
CINETPAY_SANDBOX=true

# SMS (env defaults; the DB "sms" config section overrides them).
# Empty SMS_PROVIDER_URL disables SMS (NoOpSms).
SMS_PROVIDER_URL=
SMS_API_KEY=
SMS_SENDER=

# Fernet key encrypting config secrets at rest. REQUIRED in production.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONFIG_ENCRYPTION_KEY=

# product catalog (phase 1: hard-coded for the first migrated product).
FRAUDE_WEBINAIRE_PRICE=10000
FRAUDE_WHATSAPP_GROUP_LINK=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@caas.com

# Reconciliation worker (sync-pending-loop): seconds between iterations.
SYNC_INTERVAL_SECONDS=900

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

SITE_URL=http://localhost:8080

# Container ports exposed by compose.override.yaml. Bumping these lets you run
# several stacks side-by-side without port collisions.
API_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379
ADMINER_PORT=8081

SESSION_SECRET=
PURCHASES_RATE_LIMIT=
